# StreetBite — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

# ── REQUIRED in production ────────────────────────────────────────────────────

# Flask secret key — used to sign auth tokens.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-key-here

# Admin login credentials (no hardcoded defaults — app refuses to start without these in production)
ADMIN_CONTACT=9876543210
ADMIN_PASSWORD=ChangeThisToAStrongPassword123!

# ── OPTIONAL — Database ───────────────────────────────────────────────────────

# PostgreSQL connection string (Render / Heroku / Supabase etc.)
# If not set, the app falls back to a local SQLite file: streetbite_clean.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── OPTIONAL — Flask ──────────────────────────────────────────────────────────

# Set to 'production' to disable Flask debug mode.
# FLASK_ENV=production

# Port to run the development server on (default: 5000)
# PORT=5000
